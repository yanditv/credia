# ============================================================
# Credia — variables de producción para Coolify
# ============================================================
# Copiá este archivo a `.env` (o pegá su contenido en Coolify
# UI → Stack → Environment Variables) antes del primer deploy.
#
# Coolify inyecta estas variables al docker-compose.prod.yml.
# NO commitear el .env real con valores reales.
# ============================================================

# ---------- Postgres ----------
POSTGRES_DB=credia_db
POSTGRES_USER=credia
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# ---------- MinIO (storage de comprobantes) ----------
# El bucket público se crea solo en boot por UploadService.
MINIO_ROOT_USER=credia_minio
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_minio_password
STORAGE_BUCKET=credia-docs
# Si exponés MinIO bajo otro puerto/dominio, ajustá acá.
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ---------- API ----------
API_PORT=3001
# Origen permitido por CORS — el dominio de Vercel del frontend.
# Ej: https://credia.vercel.app o el custom domain.
CORS_ORIGIN=https://your-frontend.vercel.app

# ---------- JWT ----------
JWT_SECRET=CHANGE_ME_at_least_32_chars_random
JWT_EXPIRATION=7d
JWT_REFRESH_SECRET=CHANGE_ME_different_from_JWT_SECRET
JWT_REFRESH_EXPIRATION=30d

# ---------- Solana ----------
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
# Program ID del Anchor program desplegado en devnet.
SOLANA_PROGRAM_ID=DUS67qe9NMfLuYr99X21a7NQ12sRHZCpTCDpyGzs4T5o
# Keypair del admin (JSON array de bytes, 64 numbers). Mantenelo SECRET.
ADMIN_KEYPAIR=[1,2,3,...]

# ---------- USDC disbursement (PR #48 — feature flag) ----------
USDC_DISBURSEMENT_ENABLED=false
SOLANA_USDC_MINT=Gh9ZwEmdLJ8DscKNTkTqPbNwLNNBjuSzaG9Vp2KGtKJr
SOLANA_USDC_DECIMALS=6

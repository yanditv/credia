generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  RISK_ANALYST
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  BLOCKED
}

enum BusinessType {
  VENDOR
  MERCHANT
  DELIVERY
  TAXI
  STORE
  SERVICES
  AGRICULTURE
  OTHER
}

enum SourceType {
  DAILY_SALES
  INVOICE
  QR_PAYMENT
  DELIVERY
  REFERENCE
  OTHER
}

enum RiskLevel {
  HIGH
  MEDIUM
  ACCEPTABLE
  LOW
}

enum LoanRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum LoanStatus {
  ACTIVE
  PAID
  DEFAULTED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

enum PaymentMethod {
  CASH
  TRANSFER
  USDC_ON_CHAIN
}

model User {
  id             String    @id @default(cuid())
  fullName       String
  documentNumber String    @unique
  phone          String
  email          String    @unique
  passwordHash   String
  walletAddress  String?
  role           Role      @default(USER)
  status         UserStatus @default(PENDING)
  createdAt      DateTime  @default(now())

  businessProfile BusinessProfile?
  incomeRecords  IncomeRecord[]
  creditScores   CreditScore[]
  loanRequests   LoanRequest[]
  loans          Loan[]

  @@index([email])
  @@index([status])
}

model BusinessProfile {
  id                    String       @id @default(cuid())
  userId                String       @unique
  businessName          String
  businessType          BusinessType
  city                  String
  monthlyEstimatedIncome Decimal     @db.Decimal(12, 2)
  yearsActive           Int
  createdAt             DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model IncomeRecord {
  id          String     @id @default(cuid())
  userId      String
  sourceType  SourceType
  amount      Decimal    @db.Decimal(12, 2)
  description String?
  evidenceUrl String?
  recordDate  DateTime
  createdAt   DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, recordDate])
  @@index([userId])
}

model CreditScore {
  id              String    @id @default(cuid())
  userId          String
  score           Int
  riskLevel       RiskLevel
  maxCreditAmount Decimal   @db.Decimal(10, 2)
  scoreHash       String
  breakdown       Json
  blockchainTx    String?
  createdAt       DateTime  @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  loanRequests LoanRequest[]

  @@index([userId, createdAt])
}

model LoanRequest {
  id              String            @id @default(cuid())
  userId          String
  requestedAmount Decimal            @db.Decimal(10, 2)
  termDays        Int
  purpose         String
  status          LoanRequestStatus @default(PENDING)
  scoreId         String
  createdAt       DateTime          @default(now())

  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  score CreditScore  @relation(fields: [scoreId], references: [id])
  loan  Loan?

  @@index([status])
  @@index([userId, status])
}

model Loan {
  id              String     @id @default(cuid())
  userId          String
  loanRequestId   String     @unique
  principalAmount Decimal    @db.Decimal(10, 2)
  interestAmount  Decimal    @db.Decimal(10, 2)
  totalAmount     Decimal    @db.Decimal(10, 2)
  status          LoanStatus @default(ACTIVE)
  blockchainTx    String?
  createdAt       DateTime   @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  loanRequest LoanRequest  @relation(fields: [loanRequestId], references: [id], onDelete: Cascade)
  payments    LoanPayment[]

  @@index([status])
  @@index([userId, status])
}

model LoanPayment {
  id            String        @id @default(cuid())
  loanId        String
  amount        Decimal       @db.Decimal(10, 2)
  paymentMethod PaymentMethod
  status        PaymentStatus @default(PENDING)
  blockchainTx  String?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())

  loan Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([loanId])
  @@index([status])
}